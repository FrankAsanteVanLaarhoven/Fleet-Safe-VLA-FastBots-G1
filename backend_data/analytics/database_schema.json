  "views": {
    "company_summary": {
      "description": "Aggregated company information with latest financials",
      "sql": "SELECT c.*, fs.revenue, fs.net_income, fs.eps_diluted FROM companies c LEFT JOIN financial_statements fs ON c.company_id = fs.company_id WHERE fs.fiscal_year = (SELECT MAX(fiscal_year) FROM financial_statements)"
    },
    "market_performance": {
      "description": "Daily market performance summary",
      "sql": "SELECT company_id, date, close_price, volume, (close_price - LAG(close_price) OVER (PARTITION BY company_id ORDER BY date)) / LAG(close_price) OVER (PARTITION BY company_id ORDER BY date) * 100 as daily_return FROM market_data"
    }
  },
