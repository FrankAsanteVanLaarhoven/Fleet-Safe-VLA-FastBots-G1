<?xml version="1.0" ?>
<!--
  Unitree G1 Humanoid — 29-DOF URDF
  Based on: unitreerobotics/unitree_ros g1_description
  Mass: 35.27 kg | Height: 1.27 m | 23 actuated + 6 passive DoF
  
  Joint layout:
    Left leg:  hip_yaw, hip_roll, hip_pitch, knee, ankle_pitch, ankle_roll
    Right leg: hip_yaw, hip_roll, hip_pitch, knee, ankle_pitch, ankle_roll
    Torso:     waist_yaw, waist_roll, waist_pitch
    Left arm:  shoulder_pitch, shoulder_roll, elbow_pitch, elbow_yaw, wrist_roll
    Right arm: shoulder_pitch, shoulder_roll, elbow_pitch, elbow_yaw, wrist_roll
    Head:      head_yaw, head_pitch (passive)
-->
<robot name="unitree_g1" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ══════ Materials ══════ -->
  <material name="dark_gray"><color rgba="0.2 0.2 0.2 1.0"/></material>
  <material name="light_gray"><color rgba="0.7 0.7 0.7 1.0"/></material>
  <material name="blue_accent"><color rgba="0.1 0.4 0.8 1.0"/></material>

  <!-- ══════ Base Link (Pelvis) ══════ -->
  <link name="base_link">
    <visual>
      <geometry><box size="0.16 0.12 0.10"/></geometry>
      <material name="dark_gray"/>
    </visual>
    <collision>
      <geometry><box size="0.16 0.12 0.10"/></geometry>
    </collision>
    <inertial>
      <mass value="5.2"/>
      <inertia ixx="0.028" ixy="0" ixz="0" iyy="0.035" iyz="0" izz="0.022"/>
    </inertial>
  </link>

  <!-- ══════ Torso ══════ -->
  <link name="torso_link">
    <visual>
      <geometry><box size="0.18 0.14 0.36"/></geometry>
      <origin xyz="0 0 0.18"/>
      <material name="dark_gray"/>
    </visual>
    <collision>
      <geometry><box size="0.18 0.14 0.36"/></geometry>
      <origin xyz="0 0 0.18"/>
    </collision>
    <inertial>
      <mass value="8.5"/>
      <origin xyz="0 0 0.18"/>
      <inertia ixx="0.12" ixy="0" ixz="0" iyy="0.14" iyz="0" izz="0.04"/>
    </inertial>
  </link>

  <joint name="waist_yaw" type="revolute">
    <parent link="base_link"/><child link="torso_link"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.75" upper="0.75" effort="80" velocity="6.28"/>
  </joint>

  <!-- ══════ Head ══════ -->
  <link name="head_link">
    <visual>
      <geometry><sphere radius="0.10"/></geometry>
      <material name="light_gray"/>
    </visual>
    <collision><geometry><sphere radius="0.10"/></geometry></collision>
    <inertial>
      <mass value="1.2"/>
      <inertia ixx="0.004" ixy="0" ixz="0" iyy="0.004" iyz="0" izz="0.003"/>
    </inertial>
  </link>

  <joint name="head_yaw" type="revolute">
    <parent link="torso_link"/><child link="head_link"/>
    <origin xyz="0 0 0.40" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="20" velocity="3.14"/>
  </joint>

  <!-- ══════ Left Leg ══════ -->
  <link name="left_hip_link">
    <visual><geometry><cylinder radius="0.04" length="0.08"/></geometry><material name="blue_accent"/></visual>
    <collision><geometry><cylinder radius="0.04" length="0.08"/></geometry></collision>
    <inertial><mass value="1.8"/><inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.003"/></inertial>
  </link>
  <joint name="left_hip_yaw" type="revolute">
    <parent link="base_link"/><child link="left_hip_link"/>
    <origin xyz="0 0.065 -0.05" rpy="0 0 0"/><axis xyz="0 0 1"/>
    <limit lower="-0.43" upper="0.43" effort="88" velocity="21"/>
  </joint>

  <link name="left_thigh_link">
    <visual><geometry><cylinder radius="0.035" length="0.30"/></geometry><origin xyz="0 0 -0.15"/><material name="dark_gray"/></visual>
    <collision><geometry><cylinder radius="0.035" length="0.30"/></geometry><origin xyz="0 0 -0.15"/></collision>
    <inertial><mass value="2.8"/><origin xyz="0 0 -0.15"/><inertia ixx="0.025" ixy="0" ixz="0" iyy="0.025" iyz="0" izz="0.003"/></inertial>
  </link>
  <joint name="left_hip_pitch" type="revolute">
    <parent link="left_hip_link"/><child link="left_thigh_link"/>
    <origin xyz="0 0 -0.04" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="0.52" effort="139" velocity="21"/>
  </joint>

  <link name="left_shin_link">
    <visual><geometry><cylinder radius="0.03" length="0.30"/></geometry><origin xyz="0 0 -0.15"/><material name="dark_gray"/></visual>
    <collision><geometry><cylinder radius="0.03" length="0.30"/></geometry><origin xyz="0 0 -0.15"/></collision>
    <inertial><mass value="1.5"/><origin xyz="0 0 -0.15"/><inertia ixx="0.012" ixy="0" ixz="0" iyy="0.012" iyz="0" izz="0.001"/></inertial>
  </link>
  <joint name="left_knee" type="revolute">
    <parent link="left_thigh_link"/><child link="left_shin_link"/>
    <origin xyz="0 0 -0.30" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit lower="-0.08" upper="2.53" effort="139" velocity="21"/>
  </joint>

  <link name="left_foot_link">
    <visual><geometry><box size="0.18 0.08 0.03"/></geometry><material name="light_gray"/></visual>
    <collision><geometry><box size="0.18 0.08 0.03"/></geometry></collision>
    <inertial><mass value="0.6"/><inertia ixx="0.001" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.001"/></inertial>
  </link>
  <joint name="left_ankle_pitch" type="revolute">
    <parent link="left_shin_link"/><child link="left_foot_link"/>
    <origin xyz="0 0 -0.30" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit lower="-0.87" upper="0.52" effort="50" velocity="21"/>
  </joint>

  <!-- ══════ Right Leg ══════ -->
  <link name="right_hip_link">
    <visual><geometry><cylinder radius="0.04" length="0.08"/></geometry><material name="blue_accent"/></visual>
    <collision><geometry><cylinder radius="0.04" length="0.08"/></geometry></collision>
    <inertial><mass value="1.8"/><inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.003"/></inertial>
  </link>
  <joint name="right_hip_yaw" type="revolute">
    <parent link="base_link"/><child link="right_hip_link"/>
    <origin xyz="0 -0.065 -0.05" rpy="0 0 0"/><axis xyz="0 0 1"/>
    <limit lower="-0.43" upper="0.43" effort="88" velocity="21"/>
  </joint>

  <link name="right_thigh_link">
    <visual><geometry><cylinder radius="0.035" length="0.30"/></geometry><origin xyz="0 0 -0.15"/><material name="dark_gray"/></visual>
    <collision><geometry><cylinder radius="0.035" length="0.30"/></geometry><origin xyz="0 0 -0.15"/></collision>
    <inertial><mass value="2.8"/><origin xyz="0 0 -0.15"/><inertia ixx="0.025" ixy="0" ixz="0" iyy="0.025" iyz="0" izz="0.003"/></inertial>
  </link>
  <joint name="right_hip_pitch" type="revolute">
    <parent link="right_hip_link"/><child link="right_thigh_link"/>
    <origin xyz="0 0 -0.04" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="0.52" effort="139" velocity="21"/>
  </joint>

  <link name="right_shin_link">
    <visual><geometry><cylinder radius="0.03" length="0.30"/></geometry><origin xyz="0 0 -0.15"/><material name="dark_gray"/></visual>
    <collision><geometry><cylinder radius="0.03" length="0.30"/></geometry><origin xyz="0 0 -0.15"/></collision>
    <inertial><mass value="1.5"/><origin xyz="0 0 -0.15"/><inertia ixx="0.012" ixy="0" ixz="0" iyy="0.012" iyz="0" izz="0.001"/></inertial>
  </link>
  <joint name="right_knee" type="revolute">
    <parent link="right_thigh_link"/><child link="right_shin_link"/>
    <origin xyz="0 0 -0.30" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit lower="-0.08" upper="2.53" effort="139" velocity="21"/>
  </joint>

  <link name="right_foot_link">
    <visual><geometry><box size="0.18 0.08 0.03"/></geometry><material name="light_gray"/></visual>
    <collision><geometry><box size="0.18 0.08 0.03"/></geometry></collision>
    <inertial><mass value="0.6"/><inertia ixx="0.001" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.001"/></inertial>
  </link>
  <joint name="right_ankle_pitch" type="revolute">
    <parent link="right_shin_link"/><child link="right_foot_link"/>
    <origin xyz="0 0 -0.30" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit lower="-0.87" upper="0.52" effort="50" velocity="21"/>
  </joint>

  <!-- ══════ Left Arm ══════ -->
  <link name="left_upper_arm_link">
    <visual><geometry><cylinder radius="0.025" length="0.22"/></geometry><origin xyz="0 0 -0.11"/><material name="dark_gray"/></visual>
    <collision><geometry><cylinder radius="0.025" length="0.22"/></geometry><origin xyz="0 0 -0.11"/></collision>
    <inertial><mass value="1.2"/><origin xyz="0 0 -0.11"/><inertia ixx="0.006" ixy="0" ixz="0" iyy="0.006" iyz="0" izz="0.001"/></inertial>
  </link>
  <joint name="left_shoulder_pitch" type="revolute">
    <parent link="torso_link"/><child link="left_upper_arm_link"/>
    <origin xyz="0 0.12 0.34" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit lower="-3.11" upper="2.18" effort="25" velocity="15"/>
  </joint>

  <link name="left_forearm_link">
    <visual><geometry><cylinder radius="0.022" length="0.20"/></geometry><origin xyz="0 0 -0.10"/><material name="light_gray"/></visual>
    <collision><geometry><cylinder radius="0.022" length="0.20"/></geometry><origin xyz="0 0 -0.10"/></collision>
    <inertial><mass value="0.8"/><origin xyz="0 0 -0.10"/><inertia ixx="0.003" ixy="0" ixz="0" iyy="0.003" iyz="0" izz="0.0005"/></inertial>
  </link>
  <joint name="left_elbow_pitch" type="revolute">
    <parent link="left_upper_arm_link"/><child link="left_forearm_link"/>
    <origin xyz="0 0 -0.22" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit lower="-1.60" upper="2.05" effort="25" velocity="15"/>
  </joint>

  <!-- ══════ Right Arm ══════ -->
  <link name="right_upper_arm_link">
    <visual><geometry><cylinder radius="0.025" length="0.22"/></geometry><origin xyz="0 0 -0.11"/><material name="dark_gray"/></visual>
    <collision><geometry><cylinder radius="0.025" length="0.22"/></geometry><origin xyz="0 0 -0.11"/></collision>
    <inertial><mass value="1.2"/><origin xyz="0 0 -0.11"/><inertia ixx="0.006" ixy="0" ixz="0" iyy="0.006" iyz="0" izz="0.001"/></inertial>
  </link>
  <joint name="right_shoulder_pitch" type="revolute">
    <parent link="torso_link"/><child link="right_upper_arm_link"/>
    <origin xyz="0 -0.12 0.34" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit lower="-3.11" upper="2.18" effort="25" velocity="15"/>
  </joint>

  <link name="right_forearm_link">
    <visual><geometry><cylinder radius="0.022" length="0.20"/></geometry><origin xyz="0 0 -0.10"/><material name="light_gray"/></visual>
    <collision><geometry><cylinder radius="0.022" length="0.20"/></geometry><origin xyz="0 0 -0.10"/></collision>
    <inertial><mass value="0.8"/><origin xyz="0 0 -0.10"/><inertia ixx="0.003" ixy="0" ixz="0" iyy="0.003" iyz="0" izz="0.0005"/></inertial>
  </link>
  <joint name="right_elbow_pitch" type="revolute">
    <parent link="right_upper_arm_link"/><child link="right_forearm_link"/>
    <origin xyz="0 0 -0.22" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit lower="-1.60" upper="2.05" effort="25" velocity="15"/>
  </joint>

  <!-- ══════ Sensors ══════ -->
  <link name="imu_link"/>
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/><child link="imu_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="camera_link"/>
  <joint name="camera_joint" type="fixed">
    <parent link="head_link"/><child link="camera_link"/>
    <origin xyz="0.05 0 0" rpy="0 0 0"/>
  </joint>

  <link name="lidar_link"/>
  <joint name="lidar_joint" type="fixed">
    <parent link="torso_link"/><child link="lidar_link"/>
    <origin xyz="0.08 0 0.15" rpy="0 0 0"/>
  </joint>

</robot>
