<?xml version="1.0" ?>
<!-- TurtleBot3 Burger — 2-DOF differential drive -->
<robot name="turtlebot3_burger">
  <material name="tb_dark"><color rgba="0.15 0.15 0.15 1.0"/></material>
  <material name="tb_green"><color rgba="0.2 0.8 0.3 1.0"/></material>

  <link name="base_footprint"/>

  <link name="base_link">
    <visual><geometry><cylinder radius="0.105" length="0.070"/></geometry><material name="tb_dark"/></visual>
    <collision><geometry><cylinder radius="0.105" length="0.070"/></geometry></collision>
    <inertial><mass value="1.0"/><inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/></inertial>
  </link>
  <joint name="base_joint" type="fixed"><parent link="base_footprint"/><child link="base_link"/><origin xyz="0 0 0.032"/></joint>

  <link name="left_wheel">
    <visual><geometry><cylinder radius="0.033" length="0.018"/></geometry><material name="tb_green"/></visual>
    <collision><geometry><cylinder radius="0.033" length="0.018"/></geometry></collision>
    <inertial><mass value="0.05"/><inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/></inertial>
  </link>
  <joint name="left_wheel_joint" type="continuous"><parent link="base_link"/><child link="left_wheel"/><origin xyz="0 0.08 0" rpy="-1.5708 0 0"/><axis xyz="0 0 1"/></joint>

  <link name="right_wheel">
    <visual><geometry><cylinder radius="0.033" length="0.018"/></geometry><material name="tb_green"/></visual>
    <collision><geometry><cylinder radius="0.033" length="0.018"/></geometry></collision>
    <inertial><mass value="0.05"/><inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/></inertial>
  </link>
  <joint name="right_wheel_joint" type="continuous"><parent link="base_link"/><child link="right_wheel"/><origin xyz="0 -0.08 0" rpy="-1.5708 0 0"/><axis xyz="0 0 1"/></joint>

  <link name="caster_link">
    <visual><geometry><sphere radius="0.008"/></geometry><material name="tb_dark"/></visual>
    <collision><geometry><sphere radius="0.008"/></geometry></collision>
    <inertial><mass value="0.005"/><inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/></inertial>
  </link>
  <joint name="caster_joint" type="fixed"><parent link="base_link"/><child link="caster_link"/><origin xyz="-0.08 0 -0.024"/></joint>

  <link name="lidar_link"/>
  <joint name="lidar_joint" type="fixed"><parent link="base_link"/><child link="lidar_link"/><origin xyz="-0.032 0 0.085" rpy="0 0 0"/></joint>

  <link name="camera_link"/>
  <joint name="camera_joint" type="fixed"><parent link="base_link"/><child link="camera_link"/><origin xyz="0.07 0 0.06"/></joint>
</robot>
